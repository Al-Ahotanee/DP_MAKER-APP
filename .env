# Application
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
# Example: postgresql://[user]:[password]@[endpoint].neon.tech/eventdp?sslmode=require
DATABASE_URL="postgresql://user:password@ep-example-123456.eu-central-1.aws.neon.tech/eventdp?sslmode=require"

# JWT Authentication
JWT_SECRET="generate-a-secure-random-string-here"
JWT_EXPIRES_IN="7d"

# Cloudinary (Storage for Frame PNGs)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Admin Setup (Optional: code used during registration to elevate user to ADMIN)
ADMIN_SETUP_CODE="super-secret-admin-code"
